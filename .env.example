# VaKantti browser configuration
#
# Supabase publishable configuration is safe to include in a browser bundle.
# Authorization is enforced by PostgreSQL Row Level Security. Never put a
# service-role key, secret key, Cloudflare API token or user password here.
#
# The application contains production-safe defaults for the hosted Supabase
# project. Set these values only when targeting a different local, preview or
# staging backend.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key-here

# Optional local authenticated Playwright checks. Use a dedicated test account.
# Store equivalent CI values as encrypted GitHub Actions secrets instead of
# committing them to a file.
E2E_USER_EMAIL=test-user@example.com
E2E_USER_PASSWORD=replace-with-a-local-secret
