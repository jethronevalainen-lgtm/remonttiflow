# VaKantti — ympäristömuuttujat (esimerkkitiedosto)
#
# Nämä muuttujat vaaditaan PR:stä 'feat/supabase-auth-and-multitenancy'
# alkaen, jolloin Supabase-taustajärjestelmä kytketään käyttöön.
# Sitä ennen sovellus toimii pelkällä mock-datalla eikä näitä tarvita.
#
# Kopioi tämä tiedosto nimellä .env ja täytä todelliset arvot siihen.
# ÄLÄ KOSKAAN commitoi .env-tiedostoa versionhallintaan — se on .gitignoressa.

# Supabase-projektin URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase-projektin julkinen avain (Project Settings → API → API Keys)
# Käytä mieluiten uutta "publishable key" -avainta (sb_publishable_...),
# ei vanhaa legacy anon JWT -avainta (eyJhbGciOi...). Publishable-avain
# on suunniteltu selainkäyttöön eikä ole salaisuus.
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key-here
